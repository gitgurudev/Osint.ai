# Copy this file to .env and fill in your values

# OpenAI (required for LLM-enhanced analysis)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o          # or gpt-4o-mini (cheaper, still good)

# Have I Been Pwned (required for breach checking — $3.50/month)
# Get your key at: https://haveibeenpwned.com/API/Key
HIBP_API_KEY=

# Optional tuning (defaults shown)
SEARCH_NUM_RESULTS=10
SCRAPE_TIMEOUT=10
MAX_CONTENT_CHARS=4000
LLM_CONTENT_LIMIT=6000       # chars sent to GPT-4o (controls cost)
